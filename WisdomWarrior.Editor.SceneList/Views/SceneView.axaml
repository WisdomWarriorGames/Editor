<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WisdomWarrior.Editor.SceneList.Views.SceneView">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="HIERARCHY" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"
                   FontSize="11" />
        <TextBlock Text="Scene List TEST" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.6" />
    </DockPanel>

</UserControl>