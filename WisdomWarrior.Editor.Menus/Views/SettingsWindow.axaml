<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 xmlns:vm="clr-namespace:WisdomWarrior.Editor.Menus.ViewModels"
                 x:Class="WisdomWarrior.Editor.Menus.Views.SettingsWindow"
                 x:DataType="vm:SettingsWindowViewModel"
                 Title="Settings"
                 Width="760"
                 Height="480"
                 MinWidth="640"
                 MinHeight="400"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource SukiBackground}">

    <Window.DataTemplates>
        <DataTemplate DataType="vm:GeneralSettingsViewModel">
            <StackPanel Margin="24" Spacing="18">
                <StackPanel Spacing="4">
                    <TextBlock Text="General"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Configure editor-wide preferences."
                               Foreground="{DynamicResource SukiSecondaryTextBrush}" />
                </StackPanel>

                <suki:GlassCard Padding="18"
                                CornerRadius="8"
                                IsAnimated="False">
                    <Grid ColumnDefinitions="*,220"
                          ColumnSpacing="24"
                          RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Editor Theme" FontWeight="SemiBold" />
                            <TextBlock Text="Choose the base theme for the editor window."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SukiSecondaryTextBrush}" />
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme}" />
                    </Grid>
                </suki:GlassCard>
            </StackPanel>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="200,*">
        <Border Background="{DynamicResource SukiAlternativeBackground}"
                BorderBrush="{DynamicResource SukiBorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="12" Spacing="12">
                <TextBlock Text="Categories"
                           Margin="12,8,12,0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SukiSecondaryTextBrush}" />

                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SettingsCategoryViewModel">
                            <TextBlock Text="{Binding Title}" Margin="12,8" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding SelectedCategory}" />
    </Grid>
</suki:SukiWindow>
