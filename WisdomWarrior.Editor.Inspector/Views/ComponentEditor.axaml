<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WisdomWarrior.Editor.Inspector.Views.ComponentEditor">
    <UserControl.Styles>
        <Style Selector="TextBlock.compact-label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorLabelBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorLabelBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="NumericUpDown">
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="NumericUpDown /template/ TextBox">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="NumericUpDown TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="ColorPicker">
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Height" Value="24" />

            <Setter Property="Padding" Value="2" />

            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="-5" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="8,0,24,0" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="ComboBox /template/ ToggleButton">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>

        <Style Selector="ComboBox /template/ ContentPresenter">
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="ComboBox TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="ComboBoxItem">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>
        <Style Selector="ComboBoxItem TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource EditorInspectorValueBrush}" />
        </Style>

    </UserControl.Styles>
    <StackPanel Name="PropertiesStack" Spacing="4" />
</UserControl>
