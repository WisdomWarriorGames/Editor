<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:WisdomWarrior.Editor.Inspector.ViewModels"
             xmlns:views="clr-namespace:WisdomWarrior.Editor.Inspector.Views"
             x:Class="WisdomWarrior.Editor.Inspector.Views.Inspector"
             x:DataType="viewModels:InspectorViewModel">
    <StackPanel>
        <TextBlock FontSize="11" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10">
            <Run Text="INSPECTOR" />
            <Run Text=" (" />
            <Run Text="{Binding Name, FallbackValue='None'}" />
            <Run Text=")" />
        </TextBlock>
        <ContentControl Content="{Binding CurrentContent}">
            <ContentControl.DataTemplates>

                <DataTemplate DataType="{x:Type viewModels:EntityInspectorViewModel}">
                    <views:EntityInspector />
                </DataTemplate>

                <!-- <DataTemplate DataType="{x:Type viewModels:AssetInspectorViewModel}"> -->
                <!--     <StackPanel> -->
                <!--         <TextBlock Text="Asset Properties" FontWeight="Bold" /> -->
                <!--         <TextBlock Text="{Binding File.FullPath}" /> -->
                <!--     </StackPanel> -->
                <!-- </DataTemplate> -->

            </ContentControl.DataTemplates>
        </ContentControl>
    </StackPanel>
</UserControl>