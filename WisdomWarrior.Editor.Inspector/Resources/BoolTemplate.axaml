<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:WisdomWarrior.Editor.Inspector.Models">
    <DataTemplate x:Key="BoolTemplate" DataType="models:BoolPropertyViewModel">
        <CheckBox IsChecked="{Binding Value}" />
    </DataTemplate>
</ResourceDictionary>
