<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 xmlns:views="clr-namespace:WisdomWarrior.Editor.AssetBrowser.Views;assembly=WisdomWarrior.Editor.AssetBrowser"
                 xmlns:viewModels="clr-namespace:WisdomWarrior.Editor.Shell.ViewModels"
                 x:Class="WisdomWarrior.Editor.Shell.MainWindow"
                 x:DataType="viewModels:MainWindowViewModel"
                 Title=""
                 WindowState="Maximized"
                 BackgroundAnimationEnabled="False">

    <suki:SukiWindow.LogoContent>
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="⚔️ Wisdom Warrior Games Engine" FontSize="16" FontWeight="Bold" />
        </StackPanel>
    </suki:SukiWindow.LogoContent>

    <Grid ColumnDefinitions="4*, 4, 1*">

        <Grid Grid.Column="0" RowDefinitions="8*, 8, 3*">

            <Border Grid.Row="0" Background="#050505" Margin="10" CornerRadius="15"
                    BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="1">
                <Grid>
                    <TextBlock Text="🎮 MonoGame Viewport"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="#444" FontWeight="Bold" />
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" Background="Transparent" ResizeDirection="Rows" />

            <Grid Grid.Row="2" ColumnDefinitions="1*, 4, 4*">

                <suki:GlassCard Grid.Column="0" Margin="10,0,5,10" IsAnimated="False">
                    <TextBlock Text="📚 Solution" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.6" />
                </suki:GlassCard>

                <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns" />

                <suki:GlassCard Grid.Column="2" Margin="5,0,10,10" IsAnimated="False">
                    <views:AssetBrowserView DataContext="{Binding AssetBrowser}" />
                </suki:GlassCard>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns" />

        <Grid Grid.Column="2" RowDefinitions="1*, 4, 2*">

            <suki:GlassCard Grid.Row="0" Margin="0,10,10,5" IsAnimated="False">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="HIERARCHY" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"
                               FontSize="11" />
                    <TextBlock Text="Scene List" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.6" />
                </DockPanel>
            </suki:GlassCard>

            <GridSplitter Grid.Row="1" Background="Transparent" ResizeDirection="Rows" />

            <suki:GlassCard Grid.Row="2" Margin="0,5,10,10" IsAnimated="False">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="INSPECTOR" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,10"
                               FontSize="11" />
                    <TextBlock Text="⚙️ Components" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Opacity="0.6" />
                </DockPanel>
            </suki:GlassCard>
        </Grid>

    </Grid>
</suki:SukiWindow>