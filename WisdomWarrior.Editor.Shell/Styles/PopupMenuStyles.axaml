<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="PopupRoot">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
    </Style>

    <Style Selector="PopupRoot Border">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorPopupBorderBrush}" />
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorPopupBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="ContextMenu /template/ Border">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorPopupBorderBrush}" />
    </Style>

    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorPopupBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="MenuFlyoutPresenter /template/ Border">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorPopupBorderBrush}" />
    </Style>

    <Style Selector="FlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorPopupBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="FlyoutPresenter /template/ Border">
        <Setter Property="Background" Value="{DynamicResource EditorPopupBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EditorPopupBorderBrush}" />
    </Style>

    <Style Selector="Menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
    </Style>

    <Style Selector="Menu > MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
    </Style>

    <Style Selector="MenuFlyoutPresenter MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
    </Style>

    <Style Selector="ContextMenu MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
    </Style>

    <Style Selector="FlyoutPresenter MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
    </Style>

    <Style Selector="MenuItem /template/ ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemForegroundBrush}" />
    </Style>

    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource EditorPopupItemHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemHoverForegroundBrush}" />
    </Style>

    <Style Selector="MenuItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource EditorPopupItemHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemHoverForegroundBrush}" />
    </Style>

    <Style Selector="MenuItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource EditorPopupItemHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemHoverForegroundBrush}" />
    </Style>

    <Style Selector="MenuItem:selected">
        <Setter Property="Background" Value="{DynamicResource EditorPopupItemHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource EditorPopupItemHoverForegroundBrush}" />
    </Style>

    <Style Selector="MenuItem:disabled">
        <Setter Property="Opacity" Value="0.7" />
    </Style>
</Styles>
