<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <SolidColorBrush x:Key="PopupMenuBackgroundBrush" Color="#FF1A1C22" />
    </Styles.Resources>

    <Style Selector="PopupRoot">
        <Setter Property="Background" Value="{StaticResource PopupMenuBackgroundBrush}" />
    </Style>

    <Style Selector="PopupRoot Border">
        <Setter Property="Background" Value="{StaticResource PopupMenuBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SukiBorderBrush}" />
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{StaticResource PopupMenuBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SukiBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{StaticResource PopupMenuBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SukiBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="FlyoutPresenter">
        <Setter Property="Background" Value="{StaticResource PopupMenuBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SukiBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="Menu">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource PopupMenuBackgroundBrush}" />
    </Style>

    <Style Selector="MenuItem:pointerover">
        <Setter Property="Background" Value="#2E5BFF" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="MenuItem:selected">
        <Setter Property="Background" Value="#2E5BFF" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="MenuItem:disabled">
        <Setter Property="Foreground" Value="#88FFFFFF" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>
</Styles>
