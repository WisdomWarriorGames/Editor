<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             x:Class="WisdomWarrior.Editor.Shell.App">

    <Application.Styles>
        <suki:SukiTheme Locale="en-GB" ThemeColor="Blue" />
        <StyleInclude Source="avares://IconPacks.Avalonia.Material/Material.axaml" />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <StyleInclude Source="avares://WisdomWarrior.Editor.Shell/Styles/PopupMenuStyles.axaml" />
    </Application.Styles>

</Application>
