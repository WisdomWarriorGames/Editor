<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:WisdomWarrior.Editor.Shell"
             xmlns:suki="clr-namespace:SukiUI;assembly=SukiUI"
             xmlns:viewModels="using:WisdomWarrior.Editor.Shell.ViewModels"
             x:Class="WisdomWarrior.Editor.Shell.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>

        <DataTemplate DataType="{x:Type viewModels:EditorDocument}">
            <ContentControl Content="{Binding ContentView}" />
        </DataTemplate>

        <local:ViewLocator />

    </Application.DataTemplates>

    <Application.Styles>
        <suki:SukiTheme ThemeColor="Blue" />
        <StyleInclude Source="avares://SukiUI.Dock/Index.axaml" />
    </Application.Styles>
</Application>