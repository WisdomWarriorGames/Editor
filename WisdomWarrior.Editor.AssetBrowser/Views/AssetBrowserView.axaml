<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WisdomWarrior.Editor.AssetBrowser.ViewModels"
             x:Class="WisdomWarrior.Editor.AssetBrowser.Views.AssetBrowserView"
             x:DataType="vm:AssetBrowserViewModel">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" Padding="10" Background="#202020">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="📂 Content Browser" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CurrentPath}" Foreground="Gray" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <ListBox Grid.Row="1" ItemsSource="{Binding Items}" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Icon}" FontSize="20" />

                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>