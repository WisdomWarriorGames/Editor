<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             xmlns:icon="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:vm="clr-namespace:WisdomWarrior.Editor.AssetBrowser.ViewModels"
             xmlns:views="clr-namespace:WisdomWarrior.Editor.AssetBrowser.Views"
             x:Class="WisdomWarrior.Editor.AssetBrowser.Views.AssetBrowserView"
             x:DataType="vm:AssetBrowserViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}" />
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto, *" PointerPressed="OnBackgroundClicked">
        <Grid Grid.Row="0" Height="32" Background="Transparent" Margin="5,0,5,5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="📂" FontSize="14" VerticalAlignment="Center" Opacity="0.7" />
                <TextBlock Text="ASSET BROWSER"
                           FontSize="11"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Opacity="0.5"
                           LetterSpacing="1" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5">
                
                <Button Command="{Binding NavigateUpCommand}"
                        Classes="Flat"
                        Cursor="Hand"
                        ToolTip.Tip="Go Up One Level"
                        Padding="5"
                        Background="Transparent">
                    <icon:PackIconMaterial Kind="ArrowUp" Width="16" Height="16" Foreground="#CCC" />
                </Button>
                
                <Button Command="{Binding CreateFolderCommand}"
                        Classes="Flat"
                        Cursor="Hand"
                        ToolTip.Tip="Create New Folder"
                        Padding="5"
                        CornerRadius="4"
                        Background="Transparent">

                    <icon:PackIconMaterial Kind="FolderPlus"
                                           Width="16" Height="16"
                                           Foreground="#CCC" />
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Background="Transparent">
            <ScrollViewer.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Create New Folder" Command="{Binding CreateFolderCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="📁" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ScrollViewer.ContextMenu>
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:AssetItemView />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>