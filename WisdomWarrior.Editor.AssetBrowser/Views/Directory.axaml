<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:WisdomWarrior.Editor.AssetBrowser.ViewModels"
             xmlns:views="clr-namespace:WisdomWarrior.Editor.AssetBrowser.Views"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             x:DataType="viewModels:DirectoryViewModel"
             x:Class="WisdomWarrior.Editor.AssetBrowser.Views.Directory">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" Height="40" Background="Transparent" Margin="5,0,5,5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="2">

                            <Button Classes="Basic"
                                    Cursor="Hand"
                                    Content="{Binding Name}"
                                    Command="{Binding $parent[UserControl].DataContext.NavigateCommand}"
                                    CommandParameter="{Binding FullPath}" />

                            <TextBlock Text="›"
                                       VerticalAlignment="Center"
                                       Opacity="0.5"
                                       Margin="2,0,2,0"
                                       FontSize="16" />

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <ScrollViewer Grid.Row="1" Background="Transparent">
            <ListBox ItemsSource="{Binding Assets}"
                     SelectedItems="{Binding SelectedItems}"
                     SelectionMode="Multiple"
                     PointerPressed="OnBackgroundClicked"
                     DoubleTapped="OnDoubleTapped">

                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Create New Folder" Command="{Binding CreateFolderCommand}" />
                        <MenuItem Header="Open in Explorer" Command="{Binding OpenFolderCommand}" />
                    </ContextMenu>
                </ListBox.ContextMenu>

                <ListBox.KeyBindings>
                    <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}" />
                    <KeyBinding Gesture="Escape" Command="{Binding ResetChangesCommand}" />
                </ListBox.KeyBindings>

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Template">
                            <ControlTemplate>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </ControlTemplate>
                        </Setter>
                    </Style>

                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>

                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>

                    <Style Selector="ListBoxItem:selected suki|GlassCard">
                        <Setter Property="BorderBrush" Value="#2196F3" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>

                    <Style Selector="ListBoxItem:selected Path#SelectionTick">
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <views:Asset />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>

</UserControl>