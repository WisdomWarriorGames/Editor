<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:WisdomWarrior.Editor.AssetBrowser.ViewModels"
             xmlns:views="clr-namespace:WisdomWarrior.Editor.AssetBrowser.Views"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             x:DataType="viewModels:DirectoryViewModel"
             x:Class="WisdomWarrior.Editor.AssetBrowser.Views.Directory">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" Height="32" Background="Transparent" Margin="5,0,5,5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding RootDir}"
                           FontSize="11"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Opacity="0.5"
                           LetterSpacing="1" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Background="Transparent">
            <ListBox ItemsSource="{Binding Assets}"
                     SelectedItems="{Binding SelectedItems}"
                     SelectionMode="Multiple"
                     PointerPressed="OnBackgroundClicked">

                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Create New Folder" Command="{Binding CreateFolderCommand}" />
                    </ContextMenu>
                </ListBox.ContextMenu>

                <ListBox.KeyBindings>
                    <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}" />
                    <KeyBinding Gesture="Escape" Command="{Binding ResetChangesCommand}" />
                </ListBox.KeyBindings>

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Template">
                            <ControlTemplate>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </ControlTemplate>
                        </Setter>
                    </Style>

                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>

                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>

                    <Style Selector="ListBoxItem:selected suki|GlassCard">
                        <Setter Property="BorderBrush" Value="#2196F3" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>

                    <Style Selector="ListBoxItem:selected Path#SelectionTick">
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <views:Asset />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>

</UserControl>